---
import Base from './Base.astro';
import CTASidebar from '../components/CTASidebar.astro';

interface Props {
  title: string;
  description: string;
  niche: string;
  readTime: string;
  publishDate: string;
  slug: string;
}

const { title, description, niche, readTime, publishDate, slug } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate,
  author: {
    '@type': 'Organization',
    name: 'Happy House',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Happy House',
  },
};
---

<Base title={`${title} | Happy House`} description={description} schema={articleSchema}>
  <article class="py-16 md:py-24">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="lg:grid lg:grid-cols-[1fr_320px] lg:gap-12">
        <!-- Article content -->
        <div>
          <div class="mb-8 flex items-center gap-3">
            <span class="rounded-md bg-sky-light px-3 py-1 text-sm font-semibold text-sky-darker">{niche}</span>
            <span class="text-sm text-muted">{readTime} read</span>
          </div>
          <h1 class="mb-6 text-[40px] font-bold leading-tight text-navy md:text-[48px]">{title}</h1>
          <time class="mb-10 block text-sm text-muted" datetime={publishDate}>{new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <div class="prose prose-lg max-w-none">
            <slot />
          </div>
          <!-- Post-article CTA -->
          <div class="mt-16 rounded-xl bg-navy p-8 text-center md:p-12">
            <h2 class="mb-4 text-2xl font-bold text-white md:text-3xl">Ready to grow your business with search?</h2>
            <p class="mb-6 text-lg text-white/80">Get a free market audit and see where you stand — on Google and in AI.</p>
            <a href="/audit" class="btn-primary text-lg">Get my free market audit</a>
          </div>
        </div>
        <!-- Sidebar -->
        <aside class="hidden lg:block">
          <CTASidebar />
        </aside>
      </div>
    </div>
  </article>
</Base>
