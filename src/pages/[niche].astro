---
import Base from '../layouts/Base.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TrustAccolades from '../components/TrustAccolades.astro';
import NicheStats from '../components/NicheStats.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { niches } from '../data/niches';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return niches.map((niche) => ({
    params: { niche: niche.slug },
    props: { niche },
  }));
};

const { niche } = Astro.props;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${niche.name} SEO Services`,
  provider: {
    '@type': 'Organization',
    name: 'Happy House',
    url: 'https://happyhouseseo.com',
  },
  description: niche.metaDescription,
  areaServed: 'United States',
  serviceType: 'Search Engine Optimization',
};

const faqItems = [
  {
    question: `How long does SEO take for ${niche.name.toLowerCase()} companies?`,
    answer: `You'll see early movement in months 2–3. Real traction in months 4–6. The kind of results that change your ${niche.name.toLowerCase()} business in months 8–12. We set this expectation on day one.`,
  },
  {
    question: `How is Happy House different from other SEO agencies for ${niche.name.toLowerCase()}?`,
    answer: `We only work with home services contractors. That means we understand ${niche.name.toLowerCase()} keywords, seasonal patterns, customer behavior, and competitive dynamics better than any generalist. Plus we include AEO/GEO — AI search optimization — which most agencies haven't even heard of.`,
  },
  {
    question: 'What is AEO/GEO?',
    answer: 'AEO is Answer Engine Optimization — optimizing your content to appear in AI-generated answers on ChatGPT, Google AI Overviews, and Perplexity. GEO is Generative Engine Optimization, the broader discipline. We build this into every piece of content we produce.',
  },
  {
    question: 'How much does it cost?',
    answer: "Starting at $5,000/month with no contracts. Scope varies based on your market size and competition level. We'll give you a clear number after your free market audit.",
  },
];

const pillars = [
  { icon: '\u2699', title: 'Keywords & Technical SEO', body: niche.pillarKeywords },
  { icon: '\u270E', title: 'Content Production', body: niche.pillarContent },
  { icon: '\u25B6', title: 'Video Production', body: niche.pillarVideo },
  { icon: '\u2605', title: 'Graphic Design', body: niche.pillarDesign },
  { icon: '\u2726', title: 'AEO / GEO', body: niche.pillarAEO },
];
---

<Base
  title={niche.metaTitle}
  description={niche.metaDescription}
  schema={serviceSchema}
  faqSchema={faqItems}
>
  <!-- Hero with radial gradient overlays -->
  <section class="hero-gradient min-h-[65vh] flex items-center py-24 md:py-32">
    <div class="relative z-10 mx-auto max-w-[1200px] px-6">
      <div class="max-w-3xl">
        <span class="animate-in mb-6 inline-block rounded-full bg-sky-brand/15 px-4 py-1.5 text-sm font-semibold text-sky-brand backdrop-blur-sm border border-sky-brand/20">{niche.name}</span>
        <h1 class="animate-in delay-1 text-[40px] font-extrabold leading-[1.08] md:text-[68px]">
          <span class="gradient-text">{niche.name} SEO</span>
          <span class="text-white"> + AI visibility that generates </span>
          <span class="gradient-text">real leads</span>
        </h1>
        <p class="animate-in delay-2 mt-8 text-lg text-white/70 md:text-xl leading-relaxed max-w-2xl">Happy House builds full search acquisition systems for {niche.name.toLowerCase()} contractors — technical SEO, content, video, design, and AI search visibility. Starting at $5,000/month.</p>
        <div class="animate-in delay-3 mt-10 flex flex-wrap gap-4">
          <a href="/audit" class="btn-primary text-lg">{niche.ctaText}</a>
          <a href="#pillars" class="btn-secondary-light text-lg">See what's included</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Accolades Bar -->
  <TrustAccolades />

  <!-- Stats -->
  <NicheStats avgTicket={niche.avgTicket} niche={niche.name} />

  <!-- Why Search -->
  <section class="bg-white py-20 md:py-28">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="reveal grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:items-start">
        <div>
          <span class="mb-4 inline-block text-xs font-bold uppercase tracking-[0.3em] text-sky-brand">Why search matters</span>
          <h2 class="text-[32px] font-bold leading-tight text-navy md:text-[44px]">{niche.whySearchTitle}</h2>
        </div>
        <div>
          <p class="text-muted leading-relaxed text-lg">{niche.whySearchBody}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="bg-navy py-20 md:py-28">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="reveal mx-auto max-w-3xl text-center">
        <span class="mb-4 inline-block text-xs font-bold uppercase tracking-[0.3em] text-yellow-brand">The problem</span>
        <h2 class="mb-8 text-[32px] font-bold leading-tight text-white md:text-[44px]">{niche.problemTitle}</h2>
        <p class="text-white/60 leading-relaxed text-lg">{niche.problemBody}</p>
      </div>
    </div>
  </section>

  <!-- Five Pillars -->
  <section id="pillars" class="bg-surface py-20 md:py-28">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="mb-14 text-center reveal">
        <span class="mb-4 inline-block text-xs font-bold uppercase tracking-[0.3em] text-sky-brand">The system</span>
        <h2 class="text-[32px] font-bold text-navy md:text-[44px]">What the Happy House system looks like for {niche.name.toLowerCase()}</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {pillars.slice(0, 3).map((p, i) => (
          <div class={`glass-card p-8 reveal delay-${i + 1}`}>
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-sky-brand/10 text-2xl text-sky-brand">{p.icon}</div>
            <h3 class="mb-3 text-lg font-bold text-navy">{p.title}</h3>
            <p class="text-muted leading-relaxed text-[15px]">{p.body}</p>
          </div>
        ))}
      </div>
      <div class="mt-6 grid gap-6 md:grid-cols-2 md:mx-auto md:max-w-[800px]">
        {pillars.slice(3).map((p, i) => (
          <div class={`glass-card p-8 reveal delay-${i + 4}`}>
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-sky-brand/10 text-2xl text-sky-brand">{p.icon}</div>
            <h3 class="mb-3 text-lg font-bold text-navy">{p.title}</h3>
            <p class="text-muted leading-relaxed text-[15px]">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="bg-white py-20 md:py-28">
    <div class="mx-auto max-w-[800px] px-6">
      <div class="reveal">
        <span class="mb-4 inline-block text-xs font-bold uppercase tracking-[0.3em] text-sky-brand">Timeline</span>
        <h2 class="mb-10 text-[32px] font-bold text-navy md:text-[44px]">Realistic timeline for {niche.name.toLowerCase()}</h2>
      </div>
      <div class="space-y-6">
        {niche.timeline.split('. ').filter(s => s.startsWith('Month')).map((step, i) => {
          const [label, ...rest] = step.split(': ');
          return (
            <div class={`reveal delay-${Math.min(i + 1, 5)} flex gap-5 items-start`}>
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-sky-brand/10 text-sm font-bold text-sky-brand">{i + 1}</div>
              <div>
                <p class="font-bold text-navy">{label}</p>
                <p class="text-muted">{rest.join(': ')}.</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-surface py-20 md:py-28">
    <div class="mx-auto max-w-[800px] px-6">
      <div class="reveal mb-12 text-center">
        <span class="mb-4 inline-block text-xs font-bold uppercase tracking-[0.3em] text-sky-brand">FAQ</span>
        <h2 class="text-[32px] font-bold text-navy md:text-[44px]">Common questions about {niche.name.toLowerCase()} SEO</h2>
      </div>
      <div class="reveal">
        <FAQAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="hero-gradient py-24 md:py-32">
    <div class="relative z-10 mx-auto max-w-[800px] px-6 text-center">
      <h2 class="reveal mb-4 text-[32px] font-bold text-white md:text-[44px]">Ready to dominate {niche.name.toLowerCase()} search in your market?</h2>
      <p class="reveal delay-1 mb-10 text-lg text-white/60">Get a free market audit and see exactly where you stand — on Google and in AI.</p>
      <div class="reveal delay-2">
        <a href="/audit" class="btn-primary text-lg">{niche.ctaText}</a>
      </div>
    </div>
  </section>

  <ScrollReveal />
</Base>
