---
import Base from '../layouts/Base.astro';
---

<Base
  title="Free Contractor SEO Audit | Happy House"
  description="Get a free SEO and AI visibility audit for your contracting business. See where you rank, where your competitors rank, and where you're missing AI citations."
>
  <section class="bg-navy py-24 md:py-32">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-start">
        <!-- Copy -->
        <div>
          <h1 class="text-[40px] font-extrabold leading-[1.1] text-sky-brand md:text-[56px]">Get your free contractor SEO audit</h1>
          <p class="mt-6 text-lg text-white/80">We'll show you which keywords your competitors rank for, where you're losing traffic, whether you're appearing in AI answers, and exactly what it would take to rank #1 in your market.</p>

          <div class="mt-10 flex flex-wrap gap-4">
            <div class="flex items-center gap-2 text-white/60">
              <span class="text-sky-brand">&#10003;</span>
              <span class="text-sm">No sales pressure</span>
            </div>
            <div class="flex items-center gap-2 text-white/60">
              <span class="text-sky-brand">&#10003;</span>
              <span class="text-sm">Ready in 48 hours</span>
            </div>
            <div class="flex items-center gap-2 text-white/60">
              <span class="text-sky-brand">&#10003;</span>
              <span class="text-sm">Google + AI visibility included</span>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="rounded-xl bg-white p-8">
          <form id="audit-form" action={`https://formspree.io/f/${import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || 'your_form_id'}`} method="POST">
            <div class="space-y-5">
              <div>
                <label for="firstName" class="mb-1 block text-sm font-semibold text-navy">First name *</label>
                <input type="text" id="firstName" name="firstName" required class="w-full rounded-lg border border-border px-4 py-3 text-body focus:border-sky-brand focus:outline-none focus:ring-2 focus:ring-sky-brand/20" />
              </div>

              <div>
                <label for="businessName" class="mb-1 block text-sm font-semibold text-navy">Business name *</label>
                <input type="text" id="businessName" name="businessName" required class="w-full rounded-lg border border-border px-4 py-3 text-body focus:border-sky-brand focus:outline-none focus:ring-2 focus:ring-sky-brand/20" />
              </div>

              <div>
                <label for="niche" class="mb-1 block text-sm font-semibold text-navy">Niche *</label>
                <select id="niche" name="niche" required class="w-full rounded-lg border border-border px-4 py-3 text-body focus:border-sky-brand focus:outline-none focus:ring-2 focus:ring-sky-brand/20">
                  <option value="">Select your niche</option>
                  <option value="roofing">Roofing</option>
                  <option value="hvac">HVAC</option>
                  <option value="plumbing">Plumbing</option>
                  <option value="water-damage-restoration">Water Damage Restoration</option>
                  <option value="electrical">Electrical</option>
                  <option value="foundation-repair">Foundation Repair</option>
                  <option value="mold-remediation">Mold Remediation</option>
                  <option value="pest-control">Pest Control</option>
                </select>
              </div>

              <div>
                <label for="city" class="mb-1 block text-sm font-semibold text-navy">Primary city/market *</label>
                <input type="text" id="city" name="city" required class="w-full rounded-lg border border-border px-4 py-3 text-body focus:border-sky-brand focus:outline-none focus:ring-2 focus:ring-sky-brand/20" />
              </div>

              <div>
                <label for="website" class="mb-1 block text-sm font-semibold text-navy">Website URL *</label>
                <input type="url" id="website" name="website" required placeholder="https://" class="w-full rounded-lg border border-border px-4 py-3 text-body focus:border-sky-brand focus:outline-none focus:ring-2 focus:ring-sky-brand/20" />
              </div>

              <div>
                <label for="revenue" class="mb-1 block text-sm font-semibold text-navy">Monthly revenue *</label>
                <select id="revenue" name="revenue" required class="w-full rounded-lg border border-border px-4 py-3 text-body focus:border-sky-brand focus:outline-none focus:ring-2 focus:ring-sky-brand/20">
                  <option value="">Select range</option>
                  <option value="under-50k">Under $50k</option>
                  <option value="50k-200k">$50k–$200k</option>
                  <option value="200k-500k">$200k–$500k</option>
                  <option value="500k-1m">$500k–$1M</option>
                  <option value="over-1m">Over $1M</option>
                </select>
              </div>

              <div>
                <label for="phone" class="mb-1 block text-sm font-semibold text-navy">Phone number *</label>
                <input type="tel" id="phone" name="phone" required class="w-full rounded-lg border border-border px-4 py-3 text-body focus:border-sky-brand focus:outline-none focus:ring-2 focus:ring-sky-brand/20" />
              </div>

              <div>
                <label for="source" class="mb-1 block text-sm font-semibold text-navy">How did you hear about us?</label>
                <input type="text" id="source" name="source" class="w-full rounded-lg border border-border px-4 py-3 text-body focus:border-sky-brand focus:outline-none focus:ring-2 focus:ring-sky-brand/20" />
              </div>

              <button type="submit" class="w-full rounded-lg bg-yellow-brand px-8 py-4 text-lg font-bold text-navy transition hover:brightness-110">
                Send me my free audit
              </button>
            </div>
          </form>

          <!-- Success message -->
          <div id="audit-success" class="hidden text-center py-8">
            <div class="mb-4 text-4xl">&#10003;</div>
            <h3 class="mb-3 text-xl font-bold text-navy">We'll have your audit ready within 48 hours.</h3>
            <p class="text-muted">We'll cover your Google rankings, your AI search visibility, and your biggest opportunities. Check your phone — we'll text you when it's done.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('audit-form') as HTMLFormElement;
  const success = document.getElementById('audit-success')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      form.style.display = 'none';
      success.classList.remove('hidden');
    } catch {
      alert('Something went wrong. Please try again.');
    }
  });
</script>
