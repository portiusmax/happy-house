---
interface Props {
  headline: string;
  subheadline: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
  dark?: boolean;
}

const { headline, subheadline, primaryCta, secondaryCta, dark = true } = Astro.props;
---

<section class:list={[dark ? 'hero-gradient min-h-[65vh] flex items-center' : 'bg-white', 'py-24 md:py-32']}>
  <div class="relative z-10 mx-auto max-w-[1200px] px-6">
    <div class="max-w-3xl">
      <h1 class:list={[
        'animate-in text-[40px] font-extrabold leading-[1.08] md:text-[72px]',
        dark ? 'gradient-text' : 'text-navy'
      ]}>
        {headline}
      </h1>
      <p class:list={[
        'animate-in delay-1 mt-6 text-lg md:text-xl leading-relaxed',
        dark ? 'text-white/70' : 'text-muted'
      ]}>
        {subheadline}
      </p>
      {(primaryCta || secondaryCta) && (
        <div class="animate-in delay-2 mt-10 flex flex-wrap gap-4">
          {primaryCta && (
            <a href={primaryCta.href} class="btn-primary text-lg">
              {primaryCta.text}
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn-secondary-light text-lg">
              {secondaryCta.text}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>
