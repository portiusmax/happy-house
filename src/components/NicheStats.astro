---
interface Props {
  avgTicket: string;
  niche: string;
}

const { avgTicket, niche } = Astro.props;
---

<section class="bg-navy py-16">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6">
      <div class="glass-card-dark p-6 text-center reveal">
        <p class="text-3xl font-extrabold text-sky-brand md:text-4xl">{avgTicket}</p>
        <p class="mt-2 text-sm text-white/60">Avg job ticket</p>
      </div>
      <div class="glass-card-dark p-6 text-center reveal delay-1">
        <p class="text-3xl font-extrabold text-sky-brand md:text-4xl">10x</p>
        <p class="mt-2 text-sm text-white/60">Typical ROI</p>
      </div>
      <div class="glass-card-dark p-6 text-center reveal delay-2">
        <p class="text-3xl font-extrabold text-yellow-brand md:text-4xl">5</p>
        <p class="mt-2 text-sm text-white/60">Integrated pillars</p>
      </div>
      <div class="glass-card-dark p-6 text-center reveal delay-3">
        <p class="text-3xl font-extrabold text-sky-brand md:text-4xl">12mo</p>
        <p class="mt-2 text-sm text-white/60">Compound timeline</p>
      </div>
    </div>
  </div>
</section>
