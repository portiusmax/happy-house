---
interface Props {
  title: string;
  description: string;
  slug: string;
  niche: string;
  readTime: string;
}

const { title, description, slug, niche, readTime } = Astro.props;
---

<a href={`/insights/${slug}`} class="group block rounded-xl border border-border bg-white p-6 transition-all hover:border-l-4 hover:border-l-sky-brand hover:shadow-lg">
  <div class="mb-3 flex items-center gap-3">
    <span class="rounded-md bg-sky-light px-2 py-0.5 text-xs font-semibold text-sky-darker">{niche}</span>
    <span class="text-xs text-muted">{readTime} read</span>
  </div>
  <h3 class="mb-2 text-lg font-bold text-navy group-hover:text-sky-brand transition-colors">{title}</h3>
  <p class="text-sm text-muted leading-relaxed">{description}</p>
</a>
