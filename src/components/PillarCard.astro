---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="group rounded-xl border border-border bg-white p-8 transition-all hover:border-l-4 hover:border-l-sky-brand">
  <div class="mb-4 text-3xl">{icon}</div>
  <h3 class="mb-3 text-xl font-bold text-navy">{title}</h3>
  <p class="text-muted leading-relaxed">{description}</p>
</div>
