---
interface Props {
  name: string;
  slug: string;
  description: string;
  avgTicket: string;
}

const { name, slug, description, avgTicket } = Astro.props;
---

<a href={`/${slug}`} class="group block rounded-xl border border-border bg-white p-6 transition-all hover:border-l-4 hover:border-l-sky-brand hover:shadow-lg">
  <h3 class="mb-2 text-lg font-bold text-navy group-hover:text-sky-brand transition-colors">{name}</h3>
  <p class="mb-4 text-sm text-muted leading-relaxed">{description}</p>
  <div class="flex items-center justify-between">
    <span class="rounded-md bg-sky-light px-3 py-1 text-xs font-semibold text-sky-darker">Avg ticket: {avgTicket}</span>
    <span class="text-sm font-medium text-sky-brand opacity-0 transition group-hover:opacity-100">Learn more &rarr;</span>
  </div>
</a>
